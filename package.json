{
  "name": "aozora-reader",
  "version": "1.0.0",
  "description": "Aozora Bunko Search & Reader with TTS",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.aozora.viewer",
    "productName": "AozoraViewer",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "signAndEditExecutable": false
    },
    "files": [
      "index.html",
      "main.js",
      "script.js",
      "style.css",
      "aozora_books.csv",
      "package.json"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^26.8.1"
  }
}
