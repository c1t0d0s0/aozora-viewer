{
  "name": "aozora-viewer",
  "version": "1.1.1",
  "description": "Aozora Bunko Search & Reader with TTS",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:icon": "node scripts/make-icons.cjs",
    "build": "electron-builder --win --publish never",
    "build:win": "electron-builder --win --publish never",
    "build:mac": "electron-builder --mac --publish never"
  },
  "build": {
    "appId": "net.cuio.aozora.viewer",
    "productName": "AozoraViewer",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "icon": "build/icon.png",
      "target": [
        "dmg"
      ],
      "identity": null
    },
    "files": [
      "index.html",
      "main.js",
      "script.js",
      "style.css",
      "aozora_books.csv",
      "build/icon.ico",
      "build/icon.png",
      "package.json"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^2.1.8",
    "pngjs": "^7.0.0"
  }
}
